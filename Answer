---

### 📌 Pipeline Script

```groovy
pipeline {
    agent any

    stages {
        stage('Clone Repository') {
            steps {
                git 'https://github.com/your-username/loan-app.git'
            }
        }

        stage('Build') {
            steps {
                bat 'mvn clean install'
            }
        }

        stage('Test') {
            steps {
                bat 'mvn test'
            }
        }

        stage('Run') {
            steps {
                bat 'mvn exec:java -Dexec.mainClass="com.example.App"'
            }
        }
    }
}
```

👉 Use `sh` instead of `bat` for Linux systems

